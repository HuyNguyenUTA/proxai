# ProxAI Configuration
# Copy this file to .env and fill in your real API keys

# Server settings
PROXAI_HOST=127.0.0.1      # Use 0.0.0.0 for Docker
PROXAI_PORT=8090
PROXAI_LOG_LEVEL=INFO

# Rate limiting (requests per minute per provider)
PROXAI_RATE_LIMIT_RPM=60

# Dashboard
PROXAI_DASHBOARD_ENABLED=true
PROXAI_DASHBOARD_PORT=8091

# API Keys — these NEVER go in openclaw.json
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here
NVIDIA_API_KEY=nvapi-your-key-here
